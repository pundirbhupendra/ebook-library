            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "args": ["--flavor", "dev"]
        },
        {
            "name": "frontend staging",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_staging.dart",
            "args": ["--flavor", "staging"]
        },
        {
            "name": "frontend prod",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_prod.dart",
            "args": ["--flavor", "prod"]
        },
        {
            "name": "frontend dev (profile mode)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "args": ["--flavor", "dev"],
            "flutterMode": "profile"
        },
        {
            "name": "frontend dev (release mode)",
            "cwd": "frontend",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "args": ["--flavor", "dev"],
            "flutterMode": "release"
        }
